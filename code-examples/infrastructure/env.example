# Safe public example only. Do not use these values in a real environment.

CODIQUIZ_ENV=production
CODIQUIZ_PUBLIC_SITE_ADDRESSES=preview.codiquiz.com
CODIQUIZ_ADMIN_SITE_ADDRESSES=admin.preview.codiquiz.com
CODIQUIZ_CORS_ALLOWED_ORIGINS=https://preview.codiquiz.com,https://admin.preview.codiquiz.com

POSTGRES_DB=codiquiz_db
POSTGRES_USER=codiquiz_user
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://codiquiz_user:replace-with-a-long-random-password@postgres:5432/codiquiz_db

REDIS_URL=redis://redis:6379/0
AI_GENERATION_PROVIDER=mock
OPENAI_API_KEY=replace-only-inside-question-service-environment

CODIQUIZ_AUTH_COOKIE_SECURE=true
CODIQUIZ_AUTH_COOKIE_SAMESITE=lax
PUBLIC_VISIT_STORE_RAW_IP=false
PUBLIC_VISIT_TRUST_PROXY_HEADERS=false
PUBLIC_VISIT_IP_HASH_SALT=replace-with-environment-specific-random-salt
